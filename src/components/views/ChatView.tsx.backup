        {/* Pulsing outer rings */}
        <div className="absolute -inset-2 rounded-xl bg-gradient-to-br from-purple-500 to-fuchsia-500 opacity-20 animate-ping" />
        <div className="absolute -inset-1 rounded-xl bg-gradient-to-br from-purple-500 via-violet-500 to-fuchsia-500 opacity-40 blur-sm animate-pulse" />
        <div className="relative w-11 h-11 rounded-xl flex-shrink-0 bg-gradient-to-br from-purple-500 via-violet-500 to-fuchsia-600 flex items-center justify-center shadow-xl shadow-purple-500/30">
