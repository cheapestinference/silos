                  <span className="w-0.5 h-5 bg-gradient-to-t from-purple-400 to-fuchsia-400 animate-pulse rounded-full ml-0.5" />
                </div>
              );
            })() : (
              <div className="flex items-center gap-2 py-1">
                {/* Premium wave animation */}
                <div className="flex items-center gap-1">
                  {[0, 1, 2, 3, 4].map((i) => (
                    <span
                      key={i}
                      className="w-1 bg-gradient-to-t from-purple-400 to-fuchsia-400 rounded-full animate-wave"
                      style={{
                        height: '12px',
                        animationDelay: `${i * 100}ms`,
                      }}
                    />
                  ))}
                </div>
                <span className="text-xs text-zinc-400 ml-2">{t('chat.thinkingDeeply')}</span>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

