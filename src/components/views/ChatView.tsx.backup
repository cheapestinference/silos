          "border border-purple-500/20",
          "shadow-xl shadow-purple-500/5"
        )}>
          {/* Animated gradient border effect */}
          <div className="absolute inset-0 rounded-2xl rounded-bl-md bg-gradient-to-r from-purple-500/10 via-fuchsia-500/10 to-purple-500/10 animate-gradient-x" />

          <div className="relative text-zinc-100">
