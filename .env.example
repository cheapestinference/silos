# Firebase (required — client-side auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Google Analytics (optional — omit to disable tracking)
VITE_GA_ID=

# Server-side (set these in production or Docker)
FIREBASE_PROJECT_ID=
GATEWAY_TOKEN=
OWNER_EMAIL=
OPENCLAW_BASE=/home/openclaw/.openclaw
OPENCLAW_PORT=18789
PORT=3001
